{
  "name": "qmatch",
  "private": true,
  "version": "0.0.6",
  "description": "QMatch App",
  "main": "main.js",
  "author": "QMatch",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:react": "vite build",
    "dist": "npm run build:react && electron-builder"
  },
  "build": {
    "appId": "com.qmatch.app",
    "productName": "QMatch",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "web-build/**/*",
      "assets/**/*",
      "main.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "QMatch",
      "perMachine": true,
      "runAfterFinish": true
    },
    "asarUnpack": [
      "**/ps-list/vendor/**/*"
    ]
  },
  "dependencies": {
    "@stomp/stompjs": "^7.1.1",
    "agora-rtc-sdk-ng": "^4.24.0",
    "axios": "^1.9.0",
    "dotenv": "^17.2.3",
    "ps-list": "^8.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.5.3",
    "react-toastify": "^11.0.5",
    "react-tooltip": "^5.29.1",
    "sockjs-client": "^1.6.1",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.1.4",
    "electron-builder": "^26.0.12",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3"
  }
}
